# Keskkonna Muutujad - Näide

# Umbes kopeerige see fail .env-ks ja täitke teie väärtused

# ==========================================
# SERVER SEADED
# ==========================================

# Node.js keskkond
NODE_ENV=development

# Serveri port
PORT=3000

# Serveri hostimine
HOST=localhost

# ==========================================
# DATABASE (tulevikus)
# ==========================================

# Database ühenduse string
DATABASE_URL=mongodb://localhost:27017/turvamees

# ==========================================
# API SEADED
# ==========================================

# Session salasõna
SESSION_SECRET=your-secret-key-here

# JWT token salasõna (tulevikus)
JWT_SECRET=your-jwt-secret-here

# ==========================================
# EMAIL TEENUSED (tulevikus)
# ==========================================

# SendGrid API võti
SENDGRID_API_KEY=

# Email aadress
ADMIN_EMAIL=admin@example.com

# ==========================================
# PILVEPUUTUJA TEENUSED
# ==========================================

# AWS S3 (failide salvestamine)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Google Cloud
GOOGLE_CLOUD_KEY=

# ==========================================
# MONITORING
# ==========================================

# Sentry (error tracking)
SENTRY_DSN=

# New Relic
NEW_RELIC_LICENSE_KEY=

# ==========================================
# SOCIAL MEDIA
# ==========================================

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# LOGGING
# ==========================================

# Log tase (debug, info, warn, error)
LOG_LEVEL=debug

# ==========================================
# RANDOM SALASÕNAD
# ==========================================

# Muutke neid väärtusi tootmises!
API_KEY_TEST=test-key-12345
WEBHOOK_SECRET=webhook-secret-12345
